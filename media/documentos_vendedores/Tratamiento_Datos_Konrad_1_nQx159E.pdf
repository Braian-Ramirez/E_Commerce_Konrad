<!DOCTYPE html>
<html lang="es-co">

<head>
  <script type="module" src="/@vite/client"></script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Comercial Konrad | Tienda Oficial</title>
  <!-- Tipografía moderna (Outfit) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/src/css/style.css" />
</head>

<body>
  <!-- HEADER: Navegación Principal -->
  <header class="navbar glass-effect">
    <div class="nav-brand">
      <h1>🛍️Comercial<span>Konrad</span></h1>
    </div>

    <div class="search-bar">
      <input type="text" id="searchInput" placeholder="Buscar productos increíbles...">
      <button id="searchBtn">🔍</button>
    </div>

    <nav class="nav-links">
      <a href="/pages/register.html" class="nav-item tooltip-btn">
        <span class="icon">📝</span>
        <span class="hover-text">Registrarse</span>
      </a>
      <a href="/pages/login.html" class="nav-item tooltip-btn">
        <span class="icon">🔐</span>
        <span class="hover-text">Iniciar Sesión</span>
      </a>
      <a href="/pages/check-status.html" class="nav-item tooltip-btn">
        <span class="icon">📋</span>
        <span class="hover-text">Consultar Solicitud</span>
      </a>

      <!-- Al botón del carrito lo dejamos normal o se vería raro el número solo 🛍️ 0 -->
      <button class="cart-btn">🛒 Carrito <span id="cartCount" class="badge">0</span></button>
    </nav>


  </header>

  <!-- HERO SECTION: Banner Principal de Promoción -->
  <section class="hero">
    <div class="hero-content">
      <span class="hero-badge">NUEVA COLECCIÓN 2026</span>
      <h2>Tecnología de punta al alcance de tu mano</h2>
      <p>Descubre los mejores productos vendidos por la comunidad Konradista con garantía oficial.</p>
      <button class="cta-primary">Ver Catálogo</button>
    </div>
    <div class="hero-graphics">
      <!-- Efecto decorativo abstracto -->
      <div class="floating-orb orb-1"></div>
      <div class="floating-orb orb-2"></div>
    </div>
  </section>

  <!-- SECCIÓN DE PRODUCTOS -->
  <main class="products-section">
    <div class="section-header">
      <h3>⚡ Destacados Hoy</h3>
      <div class="category-filters">
        <button class="filter-btn active">Todos</button>
        <button class="filter-btn">💻 Tecnología</button>
        <button class="filter-btn">👟 Moda</button>
        <button class="filter-btn">📚 Libros</button>
      </div>
    </div>

    <!-- Contenedor dinámico de productos -->
    <div id="productGrid" class="product-grid">
      <div class="loader-spinner">Cargando catálogo...</div>
    </div>
  </main>

  <script type="module" src="/src/js/main.js"></script>
</body>

</html>